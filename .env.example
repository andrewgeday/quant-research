# Environment configuration example
# Copy this file to .env and update with your actual values

# Market Data Pipeline
MARKET_DATA_PATH=~/git/market-data-pipeline

# Backtesting Engine
BACKTEST_ENGINE_PATH=~/git/backtesting-engine

# Data source (optional)
# ALPHA_VANTAGE_API_KEY=your_key_here
# IB_ACCOUNT=your_account_here

# Experiment settings
LOG_LEVEL=INFO
RESULTS_DIR=./results